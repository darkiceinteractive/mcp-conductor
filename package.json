{
  "name": "@darkiceinteractive/mcp-conductor",
  "version": "3.1.0-rc.1",
  "description": "MCP server that orchestrates code execution in a sandboxed Deno environment with access to all MCP servers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-conductor": "./dist/index.js",
    "mcp-conductor-cli": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "setup": "./scripts/setup.sh",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "test:benchmark": "vitest run test/benchmark",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run",
    "benchmark:scale": "tsx scripts/run-benchmarks.ts",
    "build:articles": "tsx scripts/build-articles.ts",
    "build:articles:watch": "tsx watch scripts/build-articles.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test:perf": "vitest run test/perf",
    "test:perf:bench": "vitest bench test/perf",
    "test:coverage:check": "vitest run --coverage",
    "test:popular-mcps": "vitest run test/popular-mcps",
    "test:memory-leak": "vitest run test/memory-leak",
    "test:security": "vitest run test/security",
    "record:fixtures": "tsx scripts/record-fixtures.ts",
    "benchmark:token-savings": "vitest run test/popular-mcps/token-savings",
    "test:stress": "vitest run --config vitest.stress.config.ts",
    "test:stress:full": "STRESS=1 vitest run --config vitest.stress.config.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "code-execution",
    "sandbox",
    "deno"
  ],
  "author": "DarkIce Interactive",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkiceinteractive/mcp-conductor.git"
  },
  "homepage": "https://github.com/darkiceinteractive/mcp-conductor#readme",
  "bugs": {
    "url": "https://github.com/darkiceinteractive/mcp-conductor/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "cbor-x": "^1.6.4",
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "gray-matter": "^4.0.3",
    "json-schema-to-typescript": "^15.0.4",
    "lru-cache": "^11.3.5",
    "nanoid": "^5.1.11",
    "p-queue": "^8.1.1",
    "picocolors": "^1.1.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.14.0",
    "@types/node": "^22.10.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "unified": "^11.0.5",
    "vitest": "^2.1.8"
  }
}
