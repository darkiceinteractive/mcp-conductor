{
  "name": "@darkiceinteractive/mcp-conductor",
  "version": "1.0.1",
  "description": "MCP server that orchestrates code execution in a sandboxed Deno environment with access to all MCP servers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-conductor": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "setup": "./scripts/setup.sh",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "test:benchmark": "vitest run test/benchmark",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run",
    "benchmark:scale": "tsx scripts/run-benchmarks.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "code-execution",
    "sandbox",
    "deno"
  ],
  "author": "DarkIce Interactive",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkiceinteractive/mcp-conductor.git"
  },
  "homepage": "https://github.com/darkiceinteractive/mcp-conductor#readme",
  "bugs": {
    "url": "https://github.com/darkiceinteractive/mcp-conductor/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "conf": "^13.0.1",
    "gray-matter": "^4.0.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
